# ════════════════════════════════════════════════════════════════
# Multivendor Backend — Environment Variables Template
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control — it is git-ignored.
# ════════════════════════════════════════════════════════════════

# ─── Database ────────────────────────────────────────────────────
# Individual parts (used to configure the Postgres Docker container)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=multivendor

# Full DSN — used by all Go microservices.
# When running inside Docker Compose, replace "localhost" with "postgres".
DATABASE_URL=postgres://postgres:postgres@localhost:5432/multivendor?sslmode=disable

# ─── JWT ─────────────────────────────────────────────────────────
# HMAC-SHA256 signing key shared by every service.
# Must be at least 32 characters. Generate a random value for production:
#   openssl rand -hex 32
JWT_SECRET=multivendor-super-secret-jwt-key-change-in-prod-min-32-chars

# ─── Admin Setup ─────────────────────────────────────────────────
# One-time token for POST /admin/promote  { email, admin_token }
# This promotes the first user to admin. Keep this secret.
ADMIN_SETUP_TOKEN=setup-admin-token-change-this

# ─── Payment — M-Pesa via Lipia API ──────────────────────────────
# The publicly reachable webhook URL Lipia POSTs the STK-push result to.
#
# • Local dev (use ngrok or similar):
#     ngrok http 8080
#     PAYMENT_CALLBACK_URL=https://<id>.ngrok-free.app/payments/mpesa/callback
#
# • Production:
#     PAYMENT_CALLBACK_URL=https://yourdomain.com/payments/mpesa/callback
#
# NOTE: Each store's individual mpesa_api_key is stored in the database,
#       not in this file. Admins set it via the Admin > M-Pesa panel after
#       a store submits their M-Pesa details.
PAYMENT_CALLBACK_URL=https://yourdomain.com/payments/mpesa/callback

# ─── Service URLs (gateway → microservices) ──────────────────────
# Only needed when running services directly on the host (not Docker).
# Docker Compose overrides these with internal service names automatically.
AUTH_SERVICE_URL=http://localhost:8081
STORE_SERVICE_URL=http://localhost:8082
PRODUCT_SERVICE_URL=http://localhost:8083
CART_SERVICE_URL=http://localhost:8084
PAYMENT_SERVICE_URL=http://localhost:8085
ADMIN_SERVICE_URL=http://localhost:8086
